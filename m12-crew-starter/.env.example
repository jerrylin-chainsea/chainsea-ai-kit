# 課前在「Codespaces Secrets」設定這些（不要把真 key 寫進程式或 commit！）
# 主用：GitHub Models（PAT 需勾 Models: Read 權限）
GITHUB_MODELS_TOKEN=請填_帶models權限的GitHub_PAT
# 備援（任一即可）
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
# Minimax（付費，國際站 api.minimax.io）：設了就優先用，預設模型 MiniMax-M3
# 可用 MINIMAX_MODEL 換成 MiniMax-M2 / MiniMax-Text-01，或用 MINIMAX_BASE_URL 改中國站
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
